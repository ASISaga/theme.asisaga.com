{
  "$schema": "../schema/blueprint.schema.json",
  "id": "hero",
  "name": "Hero Section",
  "version": "1.0.0",
  "description": "Above-the-fold hero section with headline, optional description, and primary CTA. The page's primary value proposition.",
  "type": "COMPONENT",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "section",
      "motion-intent": "entry/fade-in",
      "layout-variant": "entity/imperative",
      "contentRef": "include.title, include.description, include.button_text",
      "intent": "Deliver the page's primary value proposition with a headline, description, and call-to-action"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "attributes": {
    "aria-labelledby": "hero-heading"
  },
  "children": [
    {
      "id": "hero-content",
      "name": "Hero Content",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/slide-up",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-md",
      "children": [
        {
          "id": "hero-title",
          "name": "Hero Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h1",
              "motion-intent": "entry/slide-up",
              "layout-variant": "cognition/axiom"
            }
          },
          "attributes": {
            "id": "hero-heading"
          },
          "content": "{{ include.title }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 48,
              "fontWeight": 800,
              "lineHeight": {
                "value": 115,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": -2,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.067,
                "g": 0.071,
                "b": 0.102
              },
              "fontFamily": "Inter",
              "fontStyle": "Bold"
            }
          }
        },
        {
          "id": "hero-description",
          "name": "Hero Description",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "p",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/discourse"
            }
          },
          "content": "{{ include.description }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 17,
              "fontWeight": 400,
              "lineHeight": {
                "value": 160,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Georgia",
              "fontStyle": "Regular"
            }
          }
        },
        {
          "id": "hero-actions",
          "name": "Hero Actions",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "hero-primary-cta",
              "name": "Primary CTA",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "a",
                  "motion-intent": "hover/glow",
                  "layout-variant": "synapse/execute"
                }
              },
              "attributes": {
                "href": "{{ include.button_url }}"
              },
              "content": "{{ include.button_text }}",
              "figmaStyles": {
                "fills": [
                  {
                    "type": "SOLID",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988
                    },
                    "opacity": 1
                  }
                ],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 8,
                "effects": [
                  {
                    "type": "DROP_SHADOW",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988,
                      "a": 0.3
                    },
                    "offset": {
                      "x": 0,
                      "y": 4
                    },
                    "radius": 12,
                    "spread": 0,
                    "visible": true,
                    "blendMode": "NORMAL"
                  }
                ],
                "typography": {
                  "fontSize": 15,
                  "fontWeight": 600,
                  "textColor": {
                    "r": 1,
                    "g": 1,
                    "b": 1
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "SemiBold"
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "HORIZONTAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "AUTO",
              "layoutWrap": "WRAP"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "VERTICAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "FIXED",
          "maxWidth": 1120
        }
      }
    },
    {
      "id": "hero-background",
      "name": "Hero Background",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "idle/pulse",
          "layout-variant": "atmosphere/vibrant"
        }
      },
      "attributes": {
        "aria-hidden": "true"
      },
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [
          {
            "type": "DROP_SHADOW",
            "color": {
              "r": 0,
              "g": 0.549,
              "b": 0.988,
              "a": 0.15
            },
            "offset": {
              "x": 0,
              "y": 0
            },
            "radius": 12,
            "spread": 0,
            "visible": true,
            "blendMode": "NORMAL"
          },
          {
            "type": "LAYER_BLUR",
            "radius": 8,
            "visible": true
          }
        ]
      }
    }
  ],
  "figmaStyles": {
    "fills": [
      {
        "type": "SOLID",
        "color": {
          "r": 0.988,
          "g": 0.988,
          "b": 0.973
        },
        "opacity": 1
      }
    ],
    "strokes": [
      {
        "type": "SOLID",
        "color": {
          "r": 0,
          "g": 0.549,
          "b": 0.988
        },
        "opacity": 1
      }
    ],
    "strokeWeight": 2,
    "cornerRadius": 8,
    "effects": [
      {
        "type": "DROP_SHADOW",
        "color": {
          "r": 0,
          "g": 0.549,
          "b": 0.988,
          "a": 0.2
        },
        "offset": {
          "x": 0,
          "y": 0
        },
        "radius": 12,
        "spread": 0,
        "visible": true,
        "blendMode": "NORMAL"
      }
    ]
  }
}