    "consciousness": {
      "$type": "transition",
      "$value": "0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
    },
    "transcendent": {
      "$type": "transition",
      "$value": "1.2s cubic-bezier(0.165, 0.84, 0.44, 1)"
    }
