  "transition": {
    "fast": {
      "$type": "transition",
      "$value": "0.2s ease"
    },
    "normal": {
      "$type": "transition",
      "$value": "0.3s ease"
    },
    "slow": {
      "$type": "transition",
      "$value": "0.5s ease"
