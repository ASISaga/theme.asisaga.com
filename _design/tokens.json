    "overlay": {
      "$type": "other",
      "$value": "10"
    },
    "consciousness": {
      "$type": "other",
      "$value": "100"
    },
    "transcendent": {
      "$type": "other",
      "$value": "1000"
    },
    "genesis": {
      "$type": "other",
      "$value": "9999"
    }
