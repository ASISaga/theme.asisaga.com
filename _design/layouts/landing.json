{
  "$schema": "../schema/blueprint.schema.json",
  "id": "landing",
  "name": "Landing Layout",
  "version": "1.0.0",
  "description": "Marketing landing page structure: full-bleed hero above the fold, content sections below, and a final conversion CTA at the bottom.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "atmosphere/vibrant",
      "contentRef": "page content (caller-provided)",
      "intent": "Convert visitors with a full-bleed hero, content sections, and final conversion CTA"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-xl",
  "children": [
    {
      "id": "landing-hero",
      "name": "Landing Hero",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "section",
          "motion-intent": "entry/fade-in",
          "layout-variant": "entity/imperative"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-lg",
      "children": [
        {
          "id": "landing-hero-header",
          "name": "Landing Hero Header",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-md",
          "children": [
            {
              "id": "landing-hero-title",
              "name": "Landing Hero Title",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h1",
                  "motion-intent": "entry/slide-up",
                  "layout-variant": "cognition/axiom"
                }
              },
              "content": "{{ page.hero.title }}",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 48,
                  "fontWeight": 800,
                  "lineHeight": {
                    "value": 115,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": -2,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.067,
                    "g": 0.071,
                    "b": 0.102
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "Bold"
                }
              }
            },
            {
              "id": "landing-hero-subtitle",
              "name": "Landing Hero Subtitle",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "p",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/discourse"
                }
              },
              "content": "{{ page.hero.subtitle }}",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 17,
                  "fontWeight": 400,
                  "lineHeight": {
                    "value": 160,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": 0,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.082,
                    "g": 0.086,
                    "b": 0.125
                  },
                  "fontFamily": "Georgia",
                  "fontStyle": "Regular"
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "VERTICAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "FIXED",
              "maxWidth": 1120
            }
          }
        },
        {
          "id": "landing-hero-actions",
          "name": "Landing Hero Actions",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "landing-hero-cta",
              "name": "Landing Hero CTA",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "a",
                  "motion-intent": "hover/glow",
                  "layout-variant": "synapse/execute"
                }
              },
              "attributes": {
                "href": "{{ page.hero.cta.url }}"
              },
              "content": "{{ page.hero.cta.text }}",
              "figmaStyles": {
                "fills": [
                  {
                    "type": "SOLID",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988
                    },
                    "opacity": 1
                  }
                ],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 8,
                "effects": [
                  {
                    "type": "DROP_SHADOW",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988,
                      "a": 0.3
                    },
                    "offset": {
                      "x": 0,
                      "y": 4
                    },
                    "radius": 12,
                    "spread": 0,
                    "visible": true,
                    "blendMode": "NORMAL"
                  }
                ],
                "typography": {
                  "fontSize": 15,
                  "fontWeight": 600,
                  "textColor": {
                    "r": 1,
                    "g": 1,
                    "b": 1
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "SemiBold"
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "HORIZONTAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "AUTO",
              "layoutWrap": "WRAP"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
