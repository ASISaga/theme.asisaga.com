{
  "$schema": "../schema/blueprint.schema.json",
  "id": "chatroom",
  "name": "Chatroom Layout",
  "version": "1.0.0",
  "description": "Real-time chat interface layout: full-viewport chat container with message list, message composer, and optional typing indicator and connection status.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused",
      "contentRef": "site.data.chatroom, site.data.ui.states",
      "intent": "Provide a real-time chat interface with message list and message composer"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-none",
  "children": [
    {
      "id": "chatroom-app",
      "name": "Chatroom App",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-none",
      "attributes": {
        "data-chatroom": ""
      },
      "children": [
        {
          "id": "chatroom-header",
          "name": "Chatroom Header",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "header",
              "motion-intent": "entry/slide-down",
              "layout-variant": "environment/distributed"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "chatroom-title",
              "name": "Chatroom Title",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h1",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/axiom"
                }
              },
              "content": "{{ page.title }}",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 48,
                  "fontWeight": 800,
                  "lineHeight": {
                    "value": 115,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": -2,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.067,
                    "g": 0.071,
                    "b": 0.102
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "Bold"
                }
              }
            },
            {
              "id": "chatroom-participants",
              "name": "Chatroom Participants",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "span",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/gloss"
                }
              },
              "attributes": {
                "data-conditional": "page.participants"
              },
              "content": "{{ page.participants }}",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 14,
                  "fontWeight": 400,
                  "lineHeight": {
                    "value": 150,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": 0,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.306,
                    "g": 0.314,
                    "b": 0.349
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "Regular"
                }
              }
            },
            {
              "id": "chatroom-connection-status",
              "name": "Chatroom Connection Status",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "span",
                  "motion-intent": "idle/pulse",
                  "layout-variant": "state/stable"
