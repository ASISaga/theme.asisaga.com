{
  "$schema": "../schema/blueprint.schema.json",
  "id": "gallery",
  "name": "Gallery Layout",
  "version": "1.0.0",
  "description": "Media gallery layout: page title and description header, optional category filter tabs, and a distributed content grid for media items.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/distributed"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "gallery-header",
      "name": "Gallery Header",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "header",
          "motion-intent": "entry/slide-down",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-sm",
      "children": [
        {
          "id": "gallery-title",
          "name": "Gallery Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h1",
              "motion-intent": "entry/slide-up",
              "layout-variant": "cognition/axiom"
            }
          },
          "content": "{{ page.title }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 48,
              "fontWeight": 800,
              "lineHeight": {
                "value": 115,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": -2,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.067,
                "g": 0.071,
                "b": 0.102
              },
              "fontFamily": "Inter",
              "fontStyle": "Bold"
            }
          }
        },
        {
          "id": "gallery-description",
          "name": "Gallery Description",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "p",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/discourse"
            }
          },
          "attributes": {
            "data-conditional": "page.description"
          },
          "content": "{{ page.description }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 17,
              "fontWeight": 400,
              "lineHeight": {
                "value": 160,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Georgia",
              "fontStyle": "Regular"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.835,
              "g": 0.847,
              "b": 0.867
            },
            "opacity": 1
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 8,
        "effects": [
          {
            "type": "DROP_SHADOW",
            "color": {
              "r": 0.031,
              "g": 0.039,
              "b": 0.094,
              "a": 0.1
            },
            "offset": {
              "x": 0,
              "y": 1
            },
            "radius": 4,
            "spread": 0,
            "visible": true,
            "blendMode": "NORMAL"
          }
        ]
      }
    },
    {
      "id": "gallery-filters",
      "name": "Gallery Filters",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "environment/associative"
        }
      },
      "layoutMode": "HORIZONTAL",
      "itemSpacing": "spacing-sm",
      "attributes": {
        "role": "group",
        "aria-label": "Filter gallery items",
        "data-conditional": "page.categories"
      },
      "children": [
        {
          "id": "gallery-filter-all",
          "name": "Gallery Filter All",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "button",
              "motion-intent": "hover/glow",
              "layout-variant": "synapse/execute"
            }
          },
          "attributes": {
            "data-filter": "all"
          },
          "content": "All",
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0,
                  "g": 0.549,
                  "b": 0.988
                },
                "opacity": 1
              }
            ],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 8,
            "effects": [
              {
                "type": "DROP_SHADOW",
                "color": {
                  "r": 0,
                  "g": 0.549,
                  "b": 0.988,
                  "a": 0.3
                },
                "offset": {
                  "x": 0,
                  "y": 4
                },
                "radius": 12,
                "spread": 0,
                "visible": true,
                "blendMode": "NORMAL"
              }
            ],
            "typography": {
              "fontSize": 15,
              "fontWeight": 600,
              "textColor": {
                "r": 1,
                "g": 1,
                "b": 1
              },
              "fontFamily": "Inter",
              "fontStyle": "SemiBold"
            }
          }
        },
        {
          "id": "gallery-filter",
          "name": "Gallery Filter",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "button",
              "motion-intent": "hover/glow",
              "layout-variant": "synapse/execute"
            }
          },
          "attributes": {
            "data-filter": "{{ category.slug }}"
          },
          "content": "{{ category.name }}",
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0,
                  "g": 0.549,
                  "b": 0.988
                },
                "opacity": 1
              }
            ],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 8,
            "effects": [
              {
                "type": "DROP_SHADOW",
                "color": {
                  "r": 0,
                  "g": 0.549,
                  "b": 0.988,
                  "a": 0.3
                },
                "offset": {
                  "x": 0,
                  "y": 4
                },
                "radius": 12,
                "spread": 0,
                "visible": true,
                "blendMode": "NORMAL"
              }
            ],
            "typography": {
              "fontSize": 15,
              "fontWeight": 600,
              "textColor": {
                "r": 1,
                "g": 1,
                "b": 1
              },
              "fontFamily": "Inter",
              "fontStyle": "SemiBold"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "HORIZONTAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "AUTO",
          "layoutWrap": "WRAP"
        }
      }
    },
    {
      "id": "gallery-grid",
      "name": "Gallery Grid",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "scroll/reveal",
          "layout-variant": "environment/distributed"
        }
      },
      "layoutMode": "GRID",
      "itemSpacing": "spacing-md",
      "content": "{{ content }}",
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "HORIZONTAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "AUTO",
          "layoutWrap": "WRAP"
        }
      }
    }
  ],
  "figmaStyles": {
    "fills": [],
    "strokes": [],
    "strokeWeight": 0,
    "cornerRadius": 0,
    "effects": [],
    "layoutHint": {
      "layoutMode": "HORIZONTAL",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "AUTO",
      "layoutWrap": "WRAP"
    }
  }
}