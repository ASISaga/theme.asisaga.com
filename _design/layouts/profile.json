{
  "$schema": "../schema/blueprint.schema.json",
  "id": "profile",
  "name": "Profile Layout",
  "version": "1.0.0",
  "description": "User profile page: avatar and identity header, rich bio content area, and an optional sidebar with statistics and skills.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused",
      "contentRef": "site.data.ui.profile",
      "intent": "Display a user profile with avatar, bio, statistics, and skills"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "profile-header",
      "name": "Profile Header",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "header",
          "motion-intent": "entry/slide-down",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "HORIZONTAL",
      "itemSpacing": "spacing-lg",
      "children": [
        {
          "id": "profile-avatar",
          "name": "Profile Avatar",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "img",
              "motion-intent": "entry/fade-in",
              "layout-variant": "entity/aggregate"
            }
          },
          "attributes": {
            "src": "{{ page.profile_image }}",
            "alt": "{{ page.name }}",
            "data-conditional": "page.profile_image"
          },
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.969,
                  "g": 0.973,
                  "b": 0.98
                },
                "opacity": 1
              }
            ],
            "strokes": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.855,
                  "g": 0.867,
                  "b": 0.886
                },
                "opacity": 1
              }
            ],
            "strokeWeight": 1,
            "cornerRadius": 8,
            "effects": []
          }
        },
        {
          "id": "profile-info",
          "name": "Profile Info",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "profile-name",
              "name": "Profile Name",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h1",
                  "motion-intent": "entry/slide-up",
                  "layout-variant": "cognition/axiom"
                }
              },
              "attributes": {
                "data-conditional": "page.name"
              },
              "content": "{{ page.name }}",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 48,
                  "fontWeight": 800,
                  "lineHeight": {
                    "value": 115,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": -2,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.067,
                    "g": 0.071,
                    "b": 0.102
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "Bold"
                }
              }
            },
            {
              "id": "profile-role",
              "name": "Profile Role",
