                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "a",
                      "motion-intent": "hover/glow",
                      "layout-variant": "synapse/social"
                    }
                  },
                  "attributes": {
                    "href": "{{ link.url }}",
                    "target": "_blank",
                    "rel": "noopener noreferrer"
                  },
                  "figmaStyles": {
                    "fills": [
                      {
                        "type": "SOLID",
                        "color": {
                          "r": 0.953,
                          "g": 0.957,
                          "b": 0.973
                        },
                        "opacity": 1
                      }
                    ],
                    "strokes": [
                      {
                        "type": "SOLID",
                        "color": {
