{
  "$schema": "../schema/blueprint.schema.json",
  "id": "search",
  "name": "Search Layout",
  "version": "1.0.0",
  "description": "Search interface layout: prominent search form header with results count, optional filter sidebar, and a results content area.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused",
      "contentRef": "site.data.ui.search",
      "intent": "Enable users to search and filter content with a prominent search form and results area"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "search-header",
      "name": "Search Header",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "header",
          "motion-intent": "entry/slide-down",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-sm",
      "children": [
        {
          "id": "search-form",
          "name": "Search Form",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "form",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "role": "search"
          },
          "children": [
            {
              "id": "search-input-group",
              "name": "Search Input Group",
              "type": "FRAME",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "div",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "environment/associative"
                }
              },
              "layoutMode": "HORIZONTAL",
              "itemSpacing": "spacing-xs",
              "children": [
                {
                  "id": "search-input",
                  "name": "Search Input",
                  "type": "INSTANCE",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "input",
                      "motion-intent": "hover/glow",
                      "layout-variant": "synapse/inquiry"
                    }
                  },
                  "attributes": {
                    "type": "search",
                    "id": "search-input",
                    "placeholder": "Search...",
                    "value": "{{ page.query }}"
                  },
                  "figmaStyles": {
                    "fills": [
                      {
                        "type": "SOLID",
                        "color": {
                          "r": 0.988,
                          "g": 0.988,
                          "b": 0.973
                        },
                        "opacity": 1
                      }
                    ],
                    "strokes": [
                      {
                        "type": "SOLID",
                        "color": {
                          "r": 0.867,
                          "g": 0.878,
                          "b": 0.898
                        },
                        "opacity": 1
                      }
                    ],
                    "strokeWeight": 1,
                    "cornerRadius": 8,
                    "effects": [],
                    "typography": {
                      "fontSize": 15,
                      "fontWeight": 400,
                      "textColor": {
                        "r": 0.082,
                        "g": 0.086,
                        "b": 0.125
                      },
                      "fontFamily": "Inter",
                      "fontStyle": "Regular"
                    }
                  }
                },
                {
                  "id": "search-submit",
                  "name": "Search Submit Button",
                  "type": "INSTANCE",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "button",
                      "motion-intent": "hover/glow",
                      "layout-variant": "synapse/execute"
                    }
                  },
                  "attributes": {
                    "type": "submit",
                    "aria-label": "Submit search"
                  },
                  "figmaStyles": {
                    "fills": [
                      {
                        "type": "SOLID",
                        "color": {
                          "r": 0,
                          "g": 0.549,
                          "b": 0.988
                        },
                        "opacity": 1
                      }
                    ],
                    "strokes": [],
                    "strokeWeight": 0,
                    "cornerRadius": 8,
                    "effects": [
                      {
                        "type": "DROP_SHADOW",
                        "color": {
                          "r": 0,
                          "g": 0.549,
                          "b": 0.988,
                          "a": 0.3
                        },
                        "offset": {
                          "x": 0,
                          "y": 4
                        },
                        "radius": 12,
                        "spread": 0,
                        "visible": true,
                        "blendMode": "NORMAL"
                      }
                    ],
                    "typography": {
                      "fontSize": 15,
                      "fontWeight": 600,
                      "textColor": {
                        "r": 1,
                        "g": 1,
                        "b": 1
                      },
                      "fontFamily": "Inter",
                      "fontStyle": "SemiBold"
                    }
                  }
                }
              ],
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "layoutHint": {
                  "layoutMode": "HORIZONTAL",
                  "primaryAxisSizingMode": "AUTO",
                  "counterAxisSizingMode": "AUTO",
                  "layoutWrap": "WRAP"
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "HORIZONTAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "AUTO",
              "layoutWrap": "WRAP"
            }
          }
        },
        {
          "id": "search-results-count",
          "name": "Search Results Count",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "p",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/gloss"
            }
          },
          "attributes": {
            "aria-live": "polite",
            "data-results-count": "",
            "data-conditional": "page.results_count"
          },
          "content": "{{ page.results_count }} results found",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 14,
              "fontWeight": 400,
              "lineHeight": {
                "value": 150,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.306,
                "g": 0.314,
                "b": 0.349
              },
              "fontFamily": "Inter",
              "fontStyle": "Regular"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.835,
              "g": 0.847,
              "b": 0.867
            },
            "opacity": 1
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 8,
        "effects": [
          {
            "type": "DROP_SHADOW",
            "color": {
              "r": 0.031,
              "g": 0.039,
              "b": 0.094,
              "a": 0.1
            },
            "offset": {
              "x": 0,
              "y": 1
            },
            "radius": 4,
            "spread": 0,
            "visible": true,
            "blendMode": "NORMAL"
          }
        ]
      }
    },
    {
      "id": "search-body",
      "name": "Search Body",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "environment/distributed"
        }
      },
      "layoutMode": "HORIZONTAL",
      "itemSpacing": "spacing-lg",
      "children": [
        {
          "id": "search-filters",
          "name": "Search Filters Sidebar",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "aside",
              "motion-intent": "entry/slide-down",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "aria-label": "Search filters",
            "data-conditional": "page.filters"
          },
          "children": [
            {
              "id": "search-filters-title",
              "name": "Search Filters Title",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h2",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/motive"
                }
              },
              "content": "Filters",
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 17,
                  "fontWeight": 600,
                  "lineHeight": {
                    "value": 150,
                    "unit": "PERCENT"
                  },
                  "letterSpacing": {
                    "value": 0,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.082,
                    "g": 0.086,
                    "b": 0.125
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "SemiBold"
                }
              }
            },
            {
              "id": "search-filter-group",
              "name": "Search Filter Group",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "section",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "environment/focused"
                }
              },
              "children": [
                {
                  "id": "search-filter-title",
                  "name": "Search Filter Group Title",
                  "type": "TEXT",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "h3",
                      "motion-intent": "entry/fade-in",
                      "layout-variant": "cognition/motive"
                    }
                  },
                  "content": "{{ filter.name }}",
                  "figmaStyles": {
                    "fills": [],
                    "strokes": [],
                    "strokeWeight": 0,
                    "cornerRadius": 0,
                    "effects": [],
                    "typography": {
                      "fontSize": 17,
                      "fontWeight": 600,
                      "lineHeight": {
                        "value": 150,
                        "unit": "PERCENT"
                      },
                      "letterSpacing": {
                        "value": 0,
                        "unit": "PERCENT"
                      },
                      "textColor": {
                        "r": 0.082,
                        "g": 0.086,
                        "b": 0.125
                      },
                      "fontFamily": "Inter",
                      "fontStyle": "SemiBold"
                    }
                  }
                }
              ],
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "layoutHint": {
                  "layoutMode": "VERTICAL",
                  "primaryAxisSizingMode": "AUTO",
                  "counterAxisSizingMode": "FIXED",
                  "maxWidth": 1120
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "VERTICAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "FIXED",
              "maxWidth": 1120
            }
          }
        },
        {
          "id": "search-results",
          "name": "Search Results",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "scroll/reveal",
              "layout-variant": "environment/distributed"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-md",
          "attributes": {
            "data-search-results": ""
          },
          "content": "{{ content }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "HORIZONTAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "AUTO",
              "layoutWrap": "WRAP"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "HORIZONTAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "AUTO",
          "layoutWrap": "WRAP"
        }
      }
    }
  ],
  "figmaStyles": {
    "fills": [],
    "strokes": [],
    "strokeWeight": 0,
    "cornerRadius": 0,
    "effects": [],
    "layoutHint": {
      "layoutMode": "VERTICAL",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "FIXED",
      "maxWidth": 1120
    }
  }
}
