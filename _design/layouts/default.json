{
  "$schema": "../schema/blueprint.schema.json",
  "id": "default",
  "name": "Default Layout",
  "version": "1.0.0",
  "description": "Base page skeleton shared by all content pages. Assembles header, skip link, main content well, footer, and ambient background layer.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "body",
      "motion-intent": "entry/fade-in",
      "layout-variant": "atmosphere/neutral",
      "contentRef": "site.data.site, site.data.ui.a11y",
      "intent": "Assemble the base page skeleton shared by all content pages"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-xs",
  "children": [
    {
      "id": "skip-link",
      "name": "Skip Link",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "a",
          "motion-intent": "entry/fade-in",
          "layout-variant": "synapse/navigate"
        }
      },
      "attributes": {
        "href": "#skip-target",
        "class": "skip-link sr-only focus-visible"
      },
      "content": "Skip to main content",
      "figmaStyles": {
        "fills": [],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.49,
              "g": 0.784,
              "b": 1
            },
            "opacity": 0
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 0,
        "effects": [],
        "typography": {
          "fontSize": 15,
          "fontWeight": 400,
          "lineHeight": {
            "value": 100,
            "unit": "PERCENT"
          },
          "textColor": {
            "r": 0.408,
            "g": 0.694,
            "b": 0.996
          },
          "fontFamily": "Inter",
          "fontStyle": "Regular"
        }
      }
    },
    {
      "id": "site-header",
      "name": "Site Header Region",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "header",
          "motion-intent": "entry/slide-down",
          "layout-variant": "environment/distributed"
        }
      },
      "ref": "includes/header",
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "HORIZONTAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "AUTO",
          "layoutWrap": "WRAP"
        }
      }
    },
    {
      "id": "main-content",
      "name": "Main Content",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "main",
          "motion-intent": "entry/fade-in",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-lg",
      "attributes": {
        "id": "skip-target",
        "tabindex": "-1"
      },
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "VERTICAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "FIXED",
          "maxWidth": 1120
        }
      }
    },
    {
      "id": "site-footer",
      "name": "Site Footer Region",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "footer",
          "motion-intent": "scroll/reveal",
          "layout-variant": "environment/distributed"
        }
      },
      "ref": "includes/footer",
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "HORIZONTAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "AUTO",
          "layoutWrap": "WRAP"
        }
      }
    },
    {
      "id": "ambient-background",
      "name": "Ambient Background",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "idle/pulse",
          "layout-variant": "atmosphere/ethereal"
        }
      },
      "attributes": {
        "aria-hidden": "true"
      },
      "children": [
        {
          "id": "ambient-particles",
          "name": "Ambient Particles",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "idle/pulse",
              "layout-variant": "atmosphere/ethereal"
            }
          },
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.988,
                  "g": 0.988,
                  "b": 0.973
                },
                "opacity": 1
              }
            ],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [
              {
                "type": "DROP_SHADOW",
                "color": {
                  "r": 0.031,
                  "g": 0.039,
                  "b": 0.094,
                  "a": 0.06
                },
                "offset": {
                  "x": 0,
                  "y": 1
                },
                "radius": 4,
                "spread": 0,
                "visible": true,
                "blendMode": "NORMAL"
              },
              {
                "type": "LAYER_BLUR",
                "radius": 10,
                "visible": true
              }
            ]
          }
        },
        {
          "id": "ambient-glow",
          "name": "Ambient Glow",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "idle/pulse",
              "layout-variant": "atmosphere/vibrant"
            }
          },
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.988,
                  "g": 0.988,
                  "b": 0.973
                },
                "opacity": 1
              }
            ],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [
              {
                "type": "DROP_SHADOW",
                "color": {
                  "r": 0,
                  "g": 0.549,
                  "b": 0.988,
                  "a": 0.15
                },
                "offset": {
                  "x": 0,
                  "y": 0
                },
                "radius": 12,
                "spread": 0,
                "visible": true,
                "blendMode": "NORMAL"
              },
              {
                "type": "LAYER_BLUR",
                "radius": 8,
                "visible": true
              }
            ]
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [
          {
            "type": "DROP_SHADOW",
            "color": {
              "r": 0.031,
              "g": 0.039,
              "b": 0.094,
              "a": 0.06
            },
            "offset": {
              "x": 0,
              "y": 1
            },
            "radius": 4,
            "spread": 0,
            "visible": true,
            "blendMode": "NORMAL"
          },
          {
            "type": "LAYER_BLUR",
            "radius": 10,
            "visible": true
          }
        ]
      }
    }
  ],
  "figmaStyles": {
    "fills": [],
    "strokes": [],
    "strokeWeight": 0,
    "cornerRadius": 0,
    "effects": []
  }
}
