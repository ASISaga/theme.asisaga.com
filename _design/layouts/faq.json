{
  "$schema": "../schema/blueprint.schema.json",
  "id": "faq",
  "name": "FAQ Layout",
  "version": "1.0.0",
  "description": "Frequently asked questions layout: page title and description header, optional live search, optional category tab filter, accordion content area, and optional contact CTA footer.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused",
      "contentRef": "site.data.ui.faq",
      "intent": "Present frequently asked questions in a searchable, categorized accordion"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "faq-header",
      "name": "FAQ Header",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "header",
          "motion-intent": "entry/slide-down",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-sm",
      "children": [
        {
          "id": "faq-title",
          "name": "FAQ Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h1",
              "motion-intent": "entry/slide-up",
              "layout-variant": "cognition/axiom"
            }
          },
          "content": "{{ page.title }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 48,
              "fontWeight": 800,
              "lineHeight": {
                "value": 115,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": -2,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.067,
                "g": 0.071,
                "b": 0.102
              },
              "fontFamily": "Inter",
              "fontStyle": "Bold"
            }
          }
        },
        {
          "id": "faq-description",
          "name": "FAQ Description",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "p",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/discourse"
            }
          },
          "attributes": {
            "data-conditional": "page.description"
          },
          "content": "{{ page.description }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 17,
              "fontWeight": 400,
              "lineHeight": {
                "value": 160,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Georgia",
              "fontStyle": "Regular"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "VERTICAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "FIXED",
          "maxWidth": 1120
        }
      }
    },
    {
      "id": "faq-search",
      "name": "FAQ Search",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "HORIZONTAL",
      "itemSpacing": "spacing-sm",
      "attributes": {
        "data-conditional": "page.search"
      },
      "children": [
        {
          "id": "faq-search-input",
          "name": "FAQ Search Input",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "input",
              "motion-intent": "hover/glow",
              "layout-variant": "synapse/inquiry"
            }
          },
          "attributes": {
            "type": "search",
            "id": "faq-search",
            "placeholder": "Search FAQ..."
          },
          "figmaStyles": {
            "fills": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.988,
                  "g": 0.988,
                  "b": 0.973
                },
                "opacity": 1
              }
            ],
            "strokes": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.867,
                  "g": 0.878,
                  "b": 0.898
                },
                "opacity": 1
              }
            ],
            "strokeWeight": 1,
            "cornerRadius": 8,
            "effects": [],
            "typography": {
              "fontSize": 15,
              "fontWeight": 400,
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Inter",
              "fontStyle": "Regular"
            }
          }
        }
