{
  "$schema": "../schema/blueprint.schema.json",
  "id": "settings",
  "name": "Settings Layout",
  "version": "1.0.0",
  "description": "Two-column settings page: vertical sidebar navigation on the left with tab links, and a main content panel on the right with title, content area, and save/cancel actions.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/convergent",
      "contentRef": "site.data.ui.settings",
      "intent": "Provide a tabbed settings interface with sidebar navigation and save/cancel actions"
    }
  },
  "layoutMode": "HORIZONTAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "settings-sidebar",
      "name": "Settings Sidebar",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "aside",
          "motion-intent": "entry/slide-down",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-sm",
      "attributes": {
        "aria-label": "Settings navigation"
      },
      "children": [
        {
          "id": "settings-sidebar-title",
          "name": "Settings Sidebar Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h2",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/motive"
            }
          },
          "content": "Settings",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 17,
              "fontWeight": 600,
              "lineHeight": {
                "value": 150,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Inter",
              "fontStyle": "SemiBold"
            }
          }
        },
        {
          "id": "settings-nav",
          "name": "Settings Navigation",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "nav",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-xs",
          "attributes": {
            "data-conditional": "page.tabs"
          },
          "children": [
            {
              "id": "settings-nav-list",
              "name": "Settings Nav List",
              "type": "FRAME",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "ul",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "environment/focused"
                }
              },
              "layoutMode": "VERTICAL",
              "itemSpacing": "spacing-xs",
              "children": [
                {
                  "id": "settings-nav-item",
                  "name": "Settings Nav Item",
                  "type": "INSTANCE",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "li",
                      "motion-intent": "entry/fade-in",
                      "layout-variant": "environment/focused"
                    }
                  },
                  "children": [
                    {
                      "id": "settings-nav-link",
                      "name": "Settings Nav Link",
                      "type": "TEXT",
                      "pluginData": {
                        "asi-saga": {
                          "semantic-tag": "a",
                          "motion-intent": "hover/glow",
                          "layout-variant": "synapse/navigate"
                        }
                      },
                      "attributes": {
                        "href": "#{{ tab.id }}",
                        "data-tab-toggle": "",
                        "role": "tab"
                      },
                      "content": "{{ tab.title }}",
                      "figmaStyles": {
                        "fills": [],
                        "strokes": [
                          {
                            "type": "SOLID",
                            "color": {
                              "r": 0.49,
                              "g": 0.784,
                              "b": 1
                            },
                            "opacity": 0
                          }
                        ],
                        "strokeWeight": 1,
                        "cornerRadius": 0,
                        "effects": [],
                        "typography": {
                          "fontSize": 15,
                          "fontWeight": 400,
                          "lineHeight": {
                            "value": 100,
                            "unit": "PERCENT"
                          },
                          "textColor": {
                            "r": 0.408,
                            "g": 0.694,
                            "b": 0.996
                          },
                          "fontFamily": "Inter",
                          "fontStyle": "Regular"
                        }
                      }
                    }
                  ],
                  "figmaStyles": {
                    "fills": [],
                    "strokes": [],
                    "strokeWeight": 0,
                    "cornerRadius": 0,
                    "effects": [],
                    "layoutHint": {
                      "layoutMode": "VERTICAL",
                      "primaryAxisSizingMode": "AUTO",
                      "counterAxisSizingMode": "FIXED",
                      "maxWidth": 1120
                    }
                  }
                }
              ],
              "figmaStyles": {
                "fills": [],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 0,
                "effects": [],
                "layoutHint": {
                  "layoutMode": "VERTICAL",
                  "primaryAxisSizingMode": "AUTO",
                  "counterAxisSizingMode": "FIXED",
                  "maxWidth": 1120
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "VERTICAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "FIXED",
              "maxWidth": 1120
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "VERTICAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "FIXED",
          "maxWidth": 1120
        }
      }
    },
    {
      "id": "settings-main",
      "name": "Settings Main Panel",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-md",
      "children": [
        {
          "id": "settings-title",
          "name": "Settings Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h1",
              "motion-intent": "entry/slide-up",
              "layout-variant": "cognition/axiom"
            }
          },
          "attributes": {
            "data-conditional": "page.title"
          },
          "content": "{{ page.title }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 48,
              "fontWeight": 800,
              "lineHeight": {
                "value": 115,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": -2,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.067,
                "g": 0.071,
                "b": 0.102
              },
              "fontFamily": "Inter",
              "fontStyle": "Bold"
            }
          }
        },
        {
          "id": "settings-content",
          "name": "Settings Content",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-md",
          "content": "{{ content }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "VERTICAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "FIXED",
              "maxWidth": 1120
            }
          }
        },
        {
          "id": "settings-actions",
          "name": "Settings Actions",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "settings-save-button",
              "name": "Settings Save Button",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "button",
                  "motion-intent": "hover/glow",
                  "layout-variant": "synapse/execute"
                }
              },
              "attributes": {
                "type": "button"
              },
              "content": "Save Changes",
              "figmaStyles": {
                "fills": [
                  {
                    "type": "SOLID",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988
                    },
                    "opacity": 1
                  }
                ],
                "strokes": [],
                "strokeWeight": 0,
                "cornerRadius": 8,
                "effects": [
                  {
                    "type": "DROP_SHADOW",
                    "color": {
                      "r": 0,
                      "g": 0.549,
                      "b": 0.988,
                      "a": 0.3
                    },
                    "offset": {
                      "x": 0,
                      "y": 4
                    },
                    "radius": 12,
                    "spread": 0,
                    "visible": true,
                    "blendMode": "NORMAL"
                  }
                ],
                "typography": {
                  "fontSize": 15,
                  "fontWeight": 600,
                  "textColor": {
                    "r": 1,
                    "g": 1,
                    "b": 1
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "SemiBold"
                }
              }
            },
            {
              "id": "settings-cancel-button",
              "name": "Settings Cancel Button",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
