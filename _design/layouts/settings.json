                  "layout-variant": "synapse/navigate"
                }
              },
              "attributes": {
                "type": "button"
              },
              "content": "Cancel",
              "figmaStyles": {
                "fills": [],
                "strokes": [
                  {
                    "type": "SOLID",
                    "color": {
                      "r": 0.49,
                      "g": 0.784,
                      "b": 1
                    },
                    "opacity": 0
                  }
                ],
                "strokeWeight": 1,
                "cornerRadius": 0,
                "effects": [],
                "typography": {
                  "fontSize": 15,
                  "fontWeight": 400,
                  "lineHeight": {
                    "value": 100,
                    "unit": "PERCENT"
                  },
                  "textColor": {
                    "r": 0.408,
                    "g": 0.694,
                    "b": 0.996
                  },
                  "fontFamily": "Inter",
                  "fontStyle": "Regular"
                }
              }
            }
          ],
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "HORIZONTAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "AUTO",
              "layoutWrap": "WRAP"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.988,
              "g": 0.988,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.835,
              "g": 0.847,
              "b": 0.867
            },
            "opacity": 1
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 8,
        "effects": [
          {
            "type": "DROP_SHADOW",
            "color": {
              "r": 0.031,
              "g": 0.039,
              "b": 0.094,
              "a": 0.1
            },
            "offset": {
              "x": 0,
              "y": 1
            },
            "radius": 4,
            "spread": 0,
            "visible": true,
            "blendMode": "NORMAL"
          }
        ]
      }
    }
  ],
  "figmaStyles": {
    "fills": [],
    "strokes": [],
    "strokeWeight": 0,
    "cornerRadius": 0,
    "effects": [],
    "layoutHint": {
      "layoutMode": "VERTICAL",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "AUTO"
    }
  }
}
