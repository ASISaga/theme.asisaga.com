{
  "$schema": "../schema/blueprint.schema.json",
  "id": "header",
  "name": "Site Header",
  "version": "1.0.0",
  "description": "Persistent site header containing brand identity, mobile toggle, and primary navigation.",
  "type": "COMPONENT",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "header",
      "motion-intent": "entry/slide-down",
      "layout-variant": "environment/distributed"
    }
  },
  "layoutMode": "HORIZONTAL",
  "itemSpacing": "spacing-md",
  "attributes": {
    "role": "banner"
  },
  "children": [
    {
      "id": "header-container",
      "name": "Header Container",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "div",
          "motion-intent": "entry/fade-in",
          "layout-variant": "environment/distributed"
        }
      },
      "layoutMode": "HORIZONTAL",
      "itemSpacing": "spacing-md",
      "children": [
        {
          "id": "header-brand",
          "name": "Brand",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "a",
              "motion-intent": "hover/scale",
              "layout-variant": "entity/primary"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "href": "/",
            "aria-label": "{{ site.title | default: site.github.repository_name }} - Home"
          },
          "children": [
            {
              "id": "header-logo",
              "name": "Logo Image",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "img",
                  "motion-intent": "idle/pulse",
                  "layout-variant": "entity/secondary"
                }
              },
              "attributes": {
                "src": "{{ '/assets/images/favicon.ico' | relative_url }}",
                "alt": ""
              }
            },
            {
              "id": "header-brand-text",
              "name": "Brand Text",
              "type": "GROUP",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "div",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/axiom"
                }
              },
              "layoutMode": "VERTICAL",
              "itemSpacing": "spacing-xs",
              "children": [
                {
                  "id": "header-site-title",
                  "name": "Site Title",
                  "type": "TEXT",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "span",
                      "motion-intent": "entry/fade-in",
                      "layout-variant": "cognition/axiom"
                    }
                  },
                  "content": "{{ site.title | default: site.github.repository_name }}"
                },
                {
                  "id": "header-tagline",
                  "name": "Site Tagline",
                  "type": "TEXT",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "span",
                      "motion-intent": "entry/fade-in",
                      "layout-variant": "cognition/gloss"
                    }
                  },
                  "content": "{{ site.description | default: site.github.project_tagline }}"
                }
              ]
            }
          ]
        },
        {
          "id": "header-nav-toggle",
          "name": "Nav Toggle",
          "type": "INSTANCE",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "button",
              "motion-intent": "hover/glow",
              "layout-variant": "synapse/navigate"
            }
          },
          "attributes": {
            "type": "button",
            "aria-expanded": "false",
            "aria-controls": "genesis-nav",
            "aria-label": "Toggle navigation menu",
            "data-nav-toggle": ""
          }
        },
        {
          "id": "header-nav",
          "name": "Primary Navigation",
          "type": "COMPONENT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "ul",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "id": "genesis-nav",
            "aria-label": "Primary navigation",
            "data-nav-menu": ""
          },
          "$schema": "../schema/blueprint.schema.json",
          "version": "1.0.0",
          "description": "Primary site navigation list, driven by site.data.nav.navigation data source.",
          "children": [
            {
              "id": "nav-item",
              "name": "Nav Item",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "li",
                  "motion-intent": "hover/scale",
                  "layout-variant": "entity/secondary"
                }
              },
              "children": [
                {
                  "id": "nav-link",
                  "name": "Nav Link",
                  "type": "TEXT",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "a",
                      "motion-intent": "hover/glow",
                      "layout-variant": "synapse/navigate"
                    }
                  },
                  "attributes": {
                    "href": "{{ item.url }}"
                  },
                  "content": "{{ item.title }}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}