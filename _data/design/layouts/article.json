{
  "$schema": "../schema/blueprint.schema.json",
  "id": "article",
  "name": "Article Layout",
  "version": "1.0.0",
  "description": "Long-form article layout: optional sticky table-of-contents sidebar alongside a primary content column with title, metadata, prose body, and optional related-articles footer.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "article",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused"
    }
  },
  "layoutMode": "HORIZONTAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "article-toc-sidebar",
      "name": "Article TOC Sidebar",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "aside",
          "motion-intent": "entry/slide-down",
          "layout-variant": "environment/focused"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-sm",
      "attributes": {
        "aria-label": "Table of contents",
        "data-conditional": "page.toc"
      },
      "children": [
        {
          "id": "article-toc-title",
          "name": "Article TOC Title",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "h2",
              "motion-intent": "entry/fade-in",
              "layout-variant": "cognition/motive"
            }
          },
          "content": "Table of Contents",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 17,
              "fontWeight": 600,
              "lineHeight": {
                "value": 150,
                "unit": "PERCENT"
              },
              "letterSpacing": {
                "value": 0,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.082,
                "g": 0.086,
                "b": 0.125
              },
              "fontFamily": "Inter",
              "fontStyle": "SemiBold"
            }
          }
        },
        {
          "id": "article-toc-nav",
          "name": "Article TOC Nav",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "nav",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-xs",
          "content": "{{ page.toc }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [],
            "strokeWeight": 0,
            "cornerRadius": 0,
            "effects": [],
            "layoutHint": {
              "layoutMode": "VERTICAL",
              "primaryAxisSizingMode": "AUTO",
              "counterAxisSizingMode": "FIXED",
              "maxWidth": 1120
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [],
        "strokes": [],
        "strokeWeight": 0,
        "cornerRadius": 0,
        "effects": [],
        "layoutHint": {
          "layoutMode": "VERTICAL",
          "primaryAxisSizingMode": "AUTO",
          "counterAxisSizingMode": "FIXED",
          "maxWidth": 1120
