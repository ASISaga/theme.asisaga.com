{
  "$schema": "../schema/blueprint.schema.json",
  "id": "post",
  "name": "Post Layout",
  "version": "1.0.0",
  "description": "Blog post article layout: optional hero image above the fold, article body with metadata and tags, main content prose, and optional social share CTA.",
  "type": "FRAME",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "div",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/focused"
    }
  },
  "layoutMode": "VERTICAL",
  "itemSpacing": "spacing-lg",
  "children": [
    {
      "id": "post-hero",
      "name": "Post Hero",
      "version": "1.0.0",
      "description": "Above-the-fold hero section with headline, optional description, and primary CTA. The page's primary value proposition.",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "section",
          "motion-intent": "entry/fade-in",
          "layout-variant": "entity/transcendent"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-lg",
      "attributes": {
        "aria-labelledby": "hero-heading",
        "data-conditional": "page.image",
        "title": "{{ page.title }}",
        "description": "{{ page.description }}",
        "image": "{{ page.image }}",
        "size": "compact"
      },
      "children": [
        {
          "id": "hero-content",
          "name": "Hero Content",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-md",
          "children": [
            {
              "id": "hero-title",
              "name": "Hero Title",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h1",
                  "motion-intent": "entry/slide-up",
                  "layout-variant": "cognition/axiom"
                }
              },
              "attributes": {
                "id": "hero-heading"
              },
              "content": "{{ include.title }}"
            },
            {
              "id": "hero-description",
              "name": "Hero Description",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "p",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/discourse"
                }
              },
              "content": "{{ include.description }}"
            },
            {
              "id": "hero-actions",
              "name": "Hero Actions",
              "type": "FRAME",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "div",
                  "motion-intent": "entry/slide-up",
                  "layout-variant": "environment/associative"
                }
              },
              "layoutMode": "HORIZONTAL",
              "itemSpacing": "spacing-sm",
              "children": [
                {
                  "id": "hero-primary-cta",
                  "name": "Primary CTA",
                  "type": "INSTANCE",
                  "pluginData": {
                    "asi-saga": {
                      "semantic-tag": "a",
                      "motion-intent": "hover/glow",
                      "layout-variant": "synapse/execute"
                    }
                  },
                  "attributes": {
                    "href": "{{ include.button_url }}"
                  },
                  "content": "{{ include.button_text }}"
                }
              ]
            }
          ]
        },
        {
          "id": "hero-background",
          "name": "Hero Background",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "idle/pulse",
              "layout-variant": "atmosphere/vibrant"
            }
          },
          "attributes": {
            "aria-hidden": "true"
          }
        }
      ]
    },
    {
      "id": "post-article",
      "name": "Post Article",
      "type": "FRAME",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "article",
          "motion-intent": "scroll/reveal",
          "layout-variant": "entity/primary"
        }
      },
      "layoutMode": "VERTICAL",
      "itemSpacing": "spacing-md",
      "children": [
        {
          "id": "post-header",
          "name": "Post Header",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "header",
              "motion-intent": "entry/slide-up",
              "layout-variant": "environment/focused"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "data-conditional": "!page.image"
          },
          "children": [
            {
              "id": "post-title",
              "name": "Post Title",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "h1",
                  "motion-intent": "entry/slide-up",
                  "layout-variant": "cognition/axiom"
                }
              },
              "content": "{{ page.title }}"
            }
          ]
        },
        {
          "id": "post-meta",
          "name": "Post Meta",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "children": [
            {
              "id": "post-date",
              "name": "Post Date",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "time",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/gloss"
                }
              },
              "content": "{{ page.date | date: '%B %d, %Y' }}"
            },
            {
              "id": "post-author",
              "name": "Post Author",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "span",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/gloss"
                }
              },
              "content": "{{ page.author }}"
            }
          ]
        },
        {
          "id": "post-tags",
          "name": "Post Tags",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "entry/fade-in",
              "layout-variant": "environment/associative"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-xs",
          "children": [
            {
              "id": "post-tag",
              "name": "Post Tag",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "a",
                  "motion-intent": "hover/glow",
                  "layout-variant": "synapse/navigate"
                }
              },
              "content": "{{ tag }}"
            }
          ]
        },
        {
          "id": "post-content",
          "name": "Post Content",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "scroll/reveal",
              "layout-variant": "cognition/discourse"
            }
          },
          "layoutMode": "VERTICAL",
          "itemSpacing": "spacing-md",
          "content": "{{ content }}"
        },
        {
          "id": "post-share-cta",
          "name": "Post Share CTA",
          "type": "FRAME",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "div",
              "motion-intent": "scroll/reveal",
              "layout-variant": "synapse/social"
            }
          },
          "layoutMode": "HORIZONTAL",
          "itemSpacing": "spacing-sm",
          "attributes": {
            "data-conditional": "page.share"
          },
          "children": [
            {
              "id": "post-share-label",
              "name": "Post Share Label",
              "type": "TEXT",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "span",
                  "motion-intent": "entry/fade-in",
                  "layout-variant": "cognition/gloss"
                }
              },
              "content": "Share this post"
            },
            {
              "id": "post-share-button",
              "name": "Post Share Button",
              "type": "INSTANCE",
              "pluginData": {
                "asi-saga": {
                  "semantic-tag": "a",
                  "motion-intent": "hover/glow",
                  "layout-variant": "synapse/social"
                }
              },
              "attributes": {
                "href": "#share"
              },
              "content": "Share"
            }
          ]
        }
      ]
    }
  ]
}