{
  "$schema": "../schema/blueprint.schema.json",
  "id": "navigation",
  "name": "Navigation",
  "version": "1.0.0",
  "description": "Primary site navigation list, driven by site.data.nav.navigation data source.",
  "type": "COMPONENT",
  "pluginData": {
    "asi-saga": {
      "semantic-tag": "ul",
      "motion-intent": "entry/fade-in",
      "layout-variant": "environment/associative"
    }
  },
  "layoutMode": "HORIZONTAL",
  "itemSpacing": "spacing-sm",
  "children": [
    {
      "id": "nav-item",
      "name": "Nav Item",
      "type": "INSTANCE",
      "pluginData": {
        "asi-saga": {
          "semantic-tag": "li",
          "motion-intent": "hover/scale",
          "layout-variant": "entity/secondary"
        }
      },
      "children": [
        {
          "id": "nav-link",
          "name": "Nav Link",
          "type": "TEXT",
          "pluginData": {
            "asi-saga": {
              "semantic-tag": "a",
              "motion-intent": "hover/glow",
              "layout-variant": "synapse/navigate"
            }
          },
          "attributes": {
            "href": "{{ item.url }}"
          },
          "content": "{{ item.title }}",
          "figmaStyles": {
            "fills": [],
            "strokes": [
              {
                "type": "SOLID",
                "color": {
                  "r": 0.49,
                  "g": 0.784,
                  "b": 1
                },
                "opacity": 0
              }
            ],
            "strokeWeight": 1,
            "cornerRadius": 0,
            "effects": [],
            "typography": {
              "fontSize": 15,
              "fontWeight": 400,
              "lineHeight": {
                "value": 100,
                "unit": "PERCENT"
              },
              "textColor": {
                "r": 0.408,
                "g": 0.694,
                "b": 0.996
              },
              "fontFamily": "Inter",
              "fontStyle": "Regular"
            }
          }
        }
      ],
      "figmaStyles": {
        "fills": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.953,
              "g": 0.957,
              "b": 0.973
            },
            "opacity": 1
          }
        ],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.867,
              "g": 0.878,
              "b": 0.898
            },
            "opacity": 1
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 8,
        "effects": []
      }
    }
  ],
  "figmaStyles": {
    "fills": [],
    "strokes": [],
    "strokeWeight": 0,
    "cornerRadius": 0,
    "effects": [],
    "layoutHint": {
      "layoutMode": "HORIZONTAL",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "AUTO",
      "layoutWrap": "WRAP"
    }
  }
}