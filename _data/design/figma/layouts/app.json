          "motion-intent": "entry/fade-in",
          "layout-variant": "synapse/navigate"
        }
      },
      "attributes": {
        "href": "#skip-target",
        "class": "skip-link sr-only focus-visible"
      },
      "content": "Skip to main content",
      "figmaStyles": {
        "fills": [],
        "strokes": [
          {
            "type": "SOLID",
            "color": {
              "r": 0.49,
              "g": 0.784,
              "b": 1
            },
            "opacity": 0
          }
        ],
        "strokeWeight": 1,
        "cornerRadius": 0,
        "effects": [],
        "typography": {
          "fontSize": 15,
          "fontWeight": 400,
          "lineHeight": {
            "value": 100,
            "unit": "PERCENT"
